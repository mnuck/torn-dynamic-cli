{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "update-spec",
      "runtimeExecutable": "curl",
      "runtimeArgs": ["-s", "https://www.torn.com/swagger/openapi.json", "-o", "cmd/torn/torn_openapi_v2.json"],
      "port": null
    },
    {
      "name": "build",
      "runtimeExecutable": "go",
      "runtimeArgs": ["build", "-o", "torn", "./cmd/torn/"],
      "port": null
    },
    {
      "name": "test",
      "runtimeExecutable": "go",
      "runtimeArgs": ["test", "./cmd/torn/"],
      "port": null
    }
  ]
}
